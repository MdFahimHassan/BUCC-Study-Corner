# Port the Express server will listen on
# Note: macOS reserves port 5000 for AirPlay Receiver, so 5001 or higher is recommended.
PORT=5001

# MongoDB Connection URI
# Local MongoDB example: mongodb://localhost:27017/study_corner
# MongoDB Atlas example: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/study_corner?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/study_corner

# JSON Web Token Secret (Use a long, secure random string in production environments)
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production

# Node environment mode (development or production)
NODE_ENV=development
