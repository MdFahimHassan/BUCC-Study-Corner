# -----------------------------------------------------------------------------
# STUDY CORNER - ENVIRONMENT CONFIGURATION TEMPLATE
# -----------------------------------------------------------------------------
# Instructions:
# 1. Copy this file and rename it to ".env" in the root directory.
# 2. Update the values below to match your local setup or production values.
# 3. Do NOT commit the ".env" file containing real credentials to Git.
# -----------------------------------------------------------------------------

# Port number for the Express backend server
PORT=5001

# Connection string for your MongoDB database instance
# For local Docker setup, use: mongodb://localhost:27017/bucc
# For cloud MongoDB Atlas, use: mongodb+srv://<username>:<password>@cluster.mongodb.net/bucc
MONGO_URI=mongodb://localhost:27017/bucc

# Secret key used for signing and verifying JWT authentication tokens.
# Change this to a long, random, cryptographically secure string in production.
JWT_SECRET=your_jwt_secret_key_here

# Secret password/phrase required during registration to sign up as an 'admin'.
# Users must provide this value when creating an account to grant them admin privileges.
ADMIN_SIGNUP_SECRET=your_admin_signup_secret_key_here
